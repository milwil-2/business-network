NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password-here
GROQ_API_KEY=your-groq-api-key-here
# HuggingFace Inference API token, used by /semantic-search to embed queries — get one at https://huggingface.co/settings/tokens
HF_API_TOKEN=
# Optional: set to enable the gated /ingest endpoint locally (leave unset to disable)
INGEST_API_KEY=
